{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Overlearn",
  "version": "0.5.3",
  "identifier": "ai.overseed.overlearn",
  "build": {
    "frontendDist": "web"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Overlearn",
        "url": "index.html",
        "width": 1160,
        "height": 760,
        "minWidth": 760,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "bin/learn"
    ]
  }
}
