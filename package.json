{
  "name": "overlearn",
  "version": "0.5.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "bun test src",
    "test:contract": "bun test test/contract",
    "test:conformance": "bun test src/adapter",
    "check:version": "bun scripts/check-version-sync.ts",
    "build": "bun build --compile ./src/cli/index.ts --outfile ./dist/learn",
    "app:copy-sidecar": "bun scripts/copy-tauri-sidecar.ts",
    "app:dev": "bun run build && bun run app:copy-sidecar && tauri dev",
    "app:build": "bun run build && bun run app:copy-sidecar && tauri build --debug"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@tauri-apps/cli": "2.10.1",
    "bun-types": "1.3.14",
    "eslint": "10.4.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.4"
  },
  "packageManager": "bun@1.3.14"
}
